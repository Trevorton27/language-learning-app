generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

model Upload {
  id         String      @id @default(cuid())
  createdAt  DateTime    @default(now())
  saved      Int
  replaced   Int
  skipped    Int
  flashcards Flashcard[]
}

model Flashcard {
  id        String   @id @default(cuid())
  front     String
  back      String
  category  String?
  createdAt DateTime @default(now())
  uploadId  String?
  upload    Upload?  @relation(fields: [uploadId], references: [id])
}
